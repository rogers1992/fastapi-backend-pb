{
  "info": {
    "name": "Paraiso Biker API",
    "description": "Complete API collection for Paraiso Biker backend (FastAPI + PostgreSQL). 35 endpoints across 7 resource groups.\n\nAuth: Login first via POST /api/auth/login, the token is auto-saved to the access_token variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
